<%- include('layout/header') %>

<% if (error) { %>
  <div class="alert alert-danger">
    <i class="bi bi-exclamation-triangle-fill me-2"></i><%= error %>
  </div>
<% } %>

<!-- ===================== Section 1: ISN_BENH_NHAN ===================== -->
<div class="d-flex justify-content-between align-items-center mb-3">
  <h5 class="fw-bold mb-0"><i class="bi bi-person-fill me-2 text-primary"></i>Bệnh nhân</h5>
  <button
    class="btn btn-primary btn-sm"
    data-bs-toggle="modal"
    data-bs-target="#modalBenhNhan"
    onclick="openAddModal('benhNhan')"
  >
    <i class="bi bi-plus-lg me-1"></i>Thêm Mới
  </button>
</div>

<div class="card shadow-sm mb-5">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover table-bordered mb-0 align-middle">
        <thead class="table-dark">
          <tr>
            <% columns1.forEach(col => { %>
              <% if (col.COLUMN_NAME === 'SERVICE_ID') { %>
                <th class="text-nowrap">Tên dịch vụ</th>
              <% } else { %>
                <th class="text-nowrap"><%= getLabel(col.COLUMN_NAME) %> <!-- <span class="fw-normal text-white-50 small">(<%= col.COLUMN_NAME %>)</span> --></th>
              <% } %>
            <% }) %>
            <th class="text-center">Thao Tác</th>
          </tr>
        </thead>
        <tbody>
          <% if (rows1.length === 0) { %>
            <tr>
              <td colspan="<%= columns1.length + 1 %>" class="text-center text-muted py-4">
                <i class="bi bi-inbox fs-4 d-block mb-1"></i>Không có dữ liệu
              </td>
            </tr>
          <% } %>
          <% rows1.forEach(row => { %>
            <tr>
              <% columns1.forEach(col => { %>
                <td>
                  <% if (col.COLUMN_NAME === 'STATUS') { %>
                    <div class="form-check form-switch mb-0">
                      <input class="form-check-input" type="checkbox" disabled
                        <%= (row[col.COLUMN_NAME] == 1 || row[col.COLUMN_NAME] === true) ? 'checked' : '' %> />
                    </div>
                  <% } else if (col.COLUMN_NAME === 'SERVICE_ID') { %>
                    <%= row._SERVICE_NAME || row[col.COLUMN_NAME] || '' %>
                  <% } else { %>
                    <%= row[col.COLUMN_NAME] !== null && row[col.COLUMN_NAME] !== undefined ? row[col.COLUMN_NAME] : '' %>
                  <% } %>
                </td>
              <% }) %>
              <td class="text-center">
                <button
                  class="btn btn-outline-secondary btn-sm edit-btn"
                  data-section="benhNhan"
                  data-row="<%- encodeURIComponent(JSON.stringify(row)) %>"
                  data-bs-toggle="modal"
                  data-bs-target="#modalBenhNhan"
                >
                  <i class="bi bi-pencil me-1"></i>Sửa
                </button>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- ===================== Section 2: ISN_LICH_KHAM ===================== -->
<div class="d-flex justify-content-between align-items-center mb-3">
  <h5 class="fw-bold mb-0"><i class="bi bi-calendar2-week me-2 text-success"></i>Lịch khám</h5>
  <button
    class="btn btn-success btn-sm"
    data-bs-toggle="modal"
    data-bs-target="#modalLichKham"
    onclick="openAddModal('lichKham')"
  >
    <i class="bi bi-plus-lg me-1"></i>Thêm Mới
  </button>
</div>

<div class="card shadow-sm">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover table-bordered mb-0 align-middle">
        <thead class="table-dark">
          <tr>
            <% columns2.forEach(col => { %>
              <% if (col.COLUMN_NAME === 'SERVICE_ID') { %>
                <th class="text-nowrap">Tên dịch vụ</th>
              <% } else { %>
                <th class="text-nowrap"><%= getLabel(col.COLUMN_NAME) %> <!-- <span class="fw-normal text-white-50 small">(<%= col.COLUMN_NAME %>)</span> --></th>
              <% } %>
            <% }) %>
            <th class="text-center">Thao Tác</th>
          </tr>
        </thead>
        <tbody>
          <% if (rows2.length === 0) { %>
            <tr>
              <td colspan="<%= columns2.length + 1 %>" class="text-center text-muted py-4">
                <i class="bi bi-inbox fs-4 d-block mb-1"></i>Không có dữ liệu
              </td>
            </tr>
          <% } %>
          <% rows2.forEach(row => { %>
            <tr>
              <% columns2.forEach(col => { %>
                <td>
                  <% if (col.COLUMN_NAME === 'STATUS') { %>
                    <div class="form-check form-switch mb-0">
                      <input class="form-check-input" type="checkbox" disabled
                        <%= (row[col.COLUMN_NAME] == 1 || row[col.COLUMN_NAME] === true) ? 'checked' : '' %> />
                    </div>
                  <% } else if (col.COLUMN_NAME === 'SERVICE_ID') { %>
                    <%= row._SERVICE_NAME || row[col.COLUMN_NAME] || '' %>
                  <% } else { %>
                    <%= row[col.COLUMN_NAME] !== null && row[col.COLUMN_NAME] !== undefined ? row[col.COLUMN_NAME] : '' %>
                  <% } %>
                </td>
              <% }) %>
              <td class="text-center">
                <button
                  class="btn btn-outline-secondary btn-sm edit-btn"
                  data-section="lichKham"
                  data-row="<%- encodeURIComponent(JSON.stringify(row)) %>"
                  data-bs-toggle="modal"
                  data-bs-target="#modalLichKham"
                >
                  <i class="bi bi-pencil me-1"></i>Sửa
