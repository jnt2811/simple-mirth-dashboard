<%- include('layout/header') %>

<% if (error) { %>
  <div class="alert alert-danger">
    <i class="bi bi-exclamation-triangle-fill me-2"></i><%= error %>
  </div>
<% } %>

<!-- Page title -->
<div class="d-flex align-items-center mb-4">
  <div>
    <h4 class="fw-bold mb-0"><i class="bi bi-grid-1x2-fill me-2 text-primary"></i>Tổng Quan Hệ Thống</h4>
    <p class="text-muted small mb-0">Dữ liệu đồng bộ qua Mirth Connect</p>
  </div>
</div>

<!-- ── Stat cards ──────────────────────────────────────────── -->
<div class="row g-3 mb-4">
  <div class="col-sm-6 col-xl-3">
    <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #0d6efd !important;">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center" style="width:56px;height:56px;flex-shrink:0">
          <i class="bi bi-people-fill fs-4 text-primary"></i>
        </div>
        <div>
          <div class="text-muted small">Tổng bệnh nhân</div>
          <div class="fw-bold fs-3 lh-1"><%= totalPatients.toLocaleString('vi-VN') %></div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-sm-6 col-xl-3">
    <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #198754 !important;">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="rounded-circle bg-success bg-opacity-10 d-flex align-items-center justify-content-center" style="width:56px;height:56px;flex-shrink:0">
          <i class="bi bi-calendar2-check-fill fs-4 text-success"></i>
        </div>
        <div>
          <div class="text-muted small">Tổng lịch khám</div>
          <div class="fw-bold fs-3 lh-1"><%= totalAppointments.toLocaleString('vi-VN') %></div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-sm-6 col-xl-3">
    <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #0dcaf0 !important;">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="rounded-circle bg-info bg-opacity-10 d-flex align-items-center justify-content-center" style="width:56px;height:56px;flex-shrink:0">
          <i class="bi bi-person-plus-fill fs-4 text-info"></i>
        </div>
        <div>
          <div class="text-muted small">Bệnh nhân hôm nay</div>
          <div class="fw-bold fs-3 lh-1"><%= todayPatients.toLocaleString('vi-VN') %></div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-sm-6 col-xl-3">
    <div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #ffc107 !important;">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="rounded-circle bg-warning bg-opacity-10 d-flex align-items-center justify-content-center" style="width:56px;height:56px;flex-shrink:0">
          <i class="bi bi-calendar-event-fill fs-4 text-warning"></i>
        </div>
        <div>
          <div class="text-muted small">Lịch khám hôm nay</div>
          <div class="fw-bold fs-3 lh-1"><%= todayAppointments.toLocaleString('vi-VN') %></div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ── Charts row ──────────────────────────────────────────── -->
<div class="row g-3 mb-4">
  <!-- Gender chart -->
  <div class="col-md-6">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-header bg-transparent border-bottom-0 pt-3 pb-0">
        <h6 class="fw-semibold mb-0"><i class="bi bi-pie-chart-fill me-2 text-primary"></i>Bệnh nhân theo giới tính</h6>
      </div>
      <div class="card-body d-flex align-items-center justify-content-center" style="min-height:220px">
        <% if (genderRows.length === 0) { %>
          <span class="text-muted"><i class="bi bi-inbox me-1"></i>Không có dữ liệu</span>
        <% } else { %>
          <canvas id="genderChart" style="max-height:200px"></canvas>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Appointment type chart -->
  <div class="col-md-6">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-header bg-transparent border-bottom-0 pt-3 pb-0">
        <h6 class="fw-semibold mb-0"><i class="bi bi-bar-chart-fill me-2 text-success"></i>Lịch khám theo loại</h6>
      </div>
      <div class="card-body d-flex align-items-center justify-content-center" style="min-height:220px">
        <% if (apptTypeRows.length === 0) { %>
          <span class="text-muted"><i class="bi bi-inbox me-1"></i>Không có dữ liệu</span>
        <% } else { %>
          <canvas id="apptTypeChart" style="max-height:200px;width:100%"></canvas>
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- ── Recent tables row ───────────────────────────────────── -->
<div class="row g-3">
  <!-- Recent patients -->
  <div class="col-lg-6">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-transparent d-flex align-items-center justify-content-between pt-3">
        <h6 class="fw-semibold mb-0"><i class="bi bi-person-lines-fill me-2 text-primary"></i>Bệnh nhân gần đây</h6>
        <a href="/patient-sync" class="btn btn-sm btn-outline-primary">Xem tất cả</a>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover table-sm mb-0 align-middle">
            <thead class="table-light">
              <tr>
                <th>ID</th>
                <th>Họ và tên</th>
                <th>Giới tính</th>
                <th>Ngày tạo</th>
              </tr>
            </thead>
            <tbody>
              <% if (recentPatients.length === 0) { %>
                <tr><td colspan="4" class="text-center text-muted py-3"><i class="bi bi-inbox me-1"></i>Không có dữ liệu</td></tr>
              <% } %>
              <% recentPatients.forEach(p => { %>
                <tr>
                  <td class="text-nowrap"><span class="badge bg-primary bg-opacity-10 text-primary"><%= p.PATIENT_ID || '—' %></span></td>
                  <td class="text-nowrap"><%= [p.LAST_NAME, p.FIRST_NAME].filter(Boolean).join(' ') || '—' %></td>
                  <td>
                    <% const g = (p.GENDER || '').toUpperCase(); %>
                    <% if (g === 'M') { %>
                      <span class="badge bg-info bg-opacity-10 text-info">Nam</span>
                    <% } else if (g === 'F') { %>
                      <span class="badge bg-danger bg-opacity-10 text-danger">Nữ</span>
                    <% } else { %>
                      <span class="badge bg-secondary bg-opacity-10 text-secondary"><%= p.GENDER || 'Khác' %></span>
                    <% } %>
                  </td>
                  <td class="text-nowrap text-muted small"><%= p.CREATED_AT ? new Date(p.CREATED_AT).toLocaleDateString('vi-VN') : '—' %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <!-- Upcoming appointments -->
  <div class="col-lg-6">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-transparent d-flex align-items-center justify-content-between pt-3">
        <h6 class="fw-semibold mb-0"><i class="bi bi-calendar2-check me-2 text-success"></i>Lịch khám sắp tới</h6>
        <a href="/appointment-sync" class="btn btn-sm btn-outline-success">Xem tất cả</a>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover table-sm mb-0 align-middle">
            <thead class="table-light">
              <tr>
                <th>ID</th>
                <th>Loại</th>
                <th>Bắt đầu</th>
                <th>Bác sĩ</th>
              </tr>
            </thead>
            <tbody>
              <% if (upcomingAppointments.length === 0) { %>
                <tr><td colspan="4" class="text-center text-muted py-3"><i class="bi bi-inbox me-1"></i>Không có lịch sắp tới</td></tr>
              <% } %>
              <% upcomingAppointments.forEach(a => { %>
                <tr>
                  <td class="text-nowrap"><span class="badge bg-success bg-opacity-10 text-success"><%= a.APPT_ID || '—' %></span></td>
                  <td class="text-nowrap small"><%= a.APPT_TYPE || '—' %></td>
                  <td class="text-nowrap text-muted small">
                    <% if (a.APPT_START) { %>
                      <%= new Date(a.APPT_START).toLocaleString('vi-VN', { dateStyle: 'short', timeStyle: 'short' }) %>
                    <% } else { %>—<% } %>
                  </td>
                  <td class="text-nowrap small"><%= a.DOCTOR_ID || '—' %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
  const PALETTE = ['#0d6efd','#198754','#0dcaf0','#ffc107','#dc3545','#6610f2','#fd7e14','#20c997','#6c757d','#adb5bd'];

  <% if (genderRows.length > 0) { %>
  new Chart(document.getElementById('genderChart'), {
    type: 'doughnut',
    data: {
      labels: <%- JSON.stringify(genderRows.map(r => r.GENDER || 'Không rõ')) %>,
      datasets: [{
        data: <%- JSON.stringify(genderRows.map(r => r.cnt)) %>,
        backgroundColor: PALETTE.slice(0, <%- genderRows.length %>),
        borderWidth: 2,
      }]
    },
    options: {
      plugins: { legend: { position: 'bottom' } },
      cutout: '60%',
    }
  });
  <% } %>

  <% if (apptTypeRows.length > 0) { %>
  new Chart(document.getElementById('apptTypeChart'), {
    type: 'bar',
    data: {
      labels: <%- JSON.stringify(apptTypeRows.map(r => r.APPT_TYPE || 'Không rõ')) %>,
      datasets: [{
        label: 'Số lượng',
        data: <%- JSON.stringify(apptTypeRows.map(r => r.cnt)) %>,
        backgroundColor: '#198754',
        borderRadius: 4,
      }]
    },
    options: {
      indexAxis: 'y',
      plugins: { legend: { display: false } },
      scales: {
        x: { ticks: { precision: 0 }, grid: { display: false } },
        y: { grid: { display: false } },
      }
    }
  });
  <% } %>
</script>

<%- include('layout/footer') %>
